n","    'work'        : ['collaborate', 'partner', 'contribute'],\n","    'made'        : ['developed', 'engineered', 'designed'],\n","    'make'        : ['develop', 'engineer', 'design'],\n","    'got'         : ['achieved', 'attained', 'secured'],\n","    'get'         : ['achieve', 'attain', 'secure'],\n","    'used'        : ['utilized', 'leveraged', 'applied'],\n","    'use'         : ['utilize', 'leverage', 'apply'],\n","    'showed'      : ['demonstrated', 'showcased', 'presented'],\n","    'show'        : ['demonstrate', 'showcase', 'present'],\n","    'fixed'       : ['resolved', 'optimized', 'rectified'],\n","    'fix'         : ['resolve', 'optimize', 'rectify'],\n","    'ran'         : ['orchestrated', 'directed', 'managed'],\n","    'run'         : ['orchestrate', 'direct', 'manage'],\n","    'looked at'   : ['analyzed', 'evaluated', 'assessed'],\n","    'look at'     : ['analyze', 'evaluate', 'assess'],\n","    'talked'      : ['communicated', 'presented', 'articulated'],\n","    'talk'        : ['communicate', 'present', 'articulate'],\n","    'tried'       : ['initiated', 'pursued', 'attempted'],\n","    'try'         : ['initiate', 'pursue', 'attempt'],\n","    'learned'     : ['mastered', 'acquired', 'developed expertise in'],\n","    'learn'       : ['master', 'acquire', 'develop expertise in'],\n","    'trained'     : ['mentored', 'coached', 'developed'],\n","    'train'       : ['mentor', 'coach', 'develop'],\n","    'built'       : ['architected', 'constructed', 'engineered'],\n","    'build'       : ['architect', 'construct', 'engineer'],\n","    'wrote'       : ['authored', 'documented', 'composed'],\n","    'write'       : ['author', 'document', 'compose'],\n","    'handled'     : ['managed', 'oversaw', 'administered'],\n","    'handle'      : ['manage', 'oversee', 'administer'],\n","    'checked'     : ['validated', 'verified', 'audited'],\n","    'check'       : ['validate', 'verify', 'audit'],\n","    'changed'     : ['transformed', 'restructured', 'optimized'],\n","    'change'      : ['transform', 'restructure', 'optimize'],\n","}\n","\n","# Step 2 - Required Resume Sections\n","required_sections = {\n","    'objective'      : ['objective', 'summary', 'profile', 'about'],\n","    'skills'         : ['skills', 'technical skills', 'competencies'],\n","    'experience'     : ['experience', 'work experience', 'employment'],\n","    'education'      : ['education', 'academic', 'qualification'],\n","    'projects'       : ['projects', 'project', 'works'],\n","    'certifications' : ['certification', 'certifications', 'certificate'],\n","    'achievements'   : ['achievements', 'accomplishments', 'awards'],\n","}\n","\n","# Step 3 - Professional Objective Templates per role\n","objective_templates = {\n","    'AI Researcher': (\n","        \"Results-driven AI Researcher with expertise in {skills}. \"\n","        \"Passionate about advancing machine learning and deep learning research \"\n","        \"to solve complex real-world problems. Seeking to leverage strong \"\n","        \"analytical and research skills to drive innovation in AI.\"\n","    ),\n","    'Cybersecurity Analyst': (\n","        \"Dedicated Cybersecurity Analyst with hands-on experience in {skills}. \"\n","        \"Committed to protecting organizational assets through proactive threat \"\n","        \"detection and incident response. Seeking to apply strong technical \"\n","        \"skills to strengthen security infrastructure.\"\n","    ),\n","    'Data Scientist': (\n","        \"Analytical Data Scientist with proven expertise in {skills}. \"\n","        \"Passionate about transforming raw data into actionable insights \"\n","        \"that drive strategic business decisions. Seeking to leverage \"\n","        \"strong ML and statistical skills in a data-driven environment.\"\n","    ),\n","    'Software Engineer': (\n","        \"Innovative Software Engineer with strong proficiency in {skills}. \"\n","        \"Experienced in designing and delivering scalable, high-performance \"\n","        \"applications. Seeking to contribute technical expertise and \"\n","        \"problem-solving skills to build impactful software solutions.\"\n","    ),\n","}\n","\n","# Step 4 - Section Checker Function\n","def check_resume_sections(resume_text):\n","    resume_lower = resume_text.lower()\n","    found_sections = []\n","    missing_sections = []\n","\n","    for section, keywords in required_sections.items():\n","        found = any(keyword in resume_lower for keyword in keywords)\n","        if found:\n","            found_sections.append(section.title())\n","        else:\n","            missing_sections.append(section.title())\n","\n","    return found_sections, missing_sections\n","\n","# Step 5 - Weak Words Detector Function\n","def detect_weak_words(resume_text):\n","    resume_lower = resume_text.lower()\n","    found_weak = {}\n","\n","    for weak_word, strong_alternatives in power_words.items():\n","        if weak_word in resume_lower:\n","            found_weak[weak_word] = strong_alternatives\n","\n","    return found_weak\n","\n","# Step 6 - Objective Generator Function\n","def generate_objective(resume_text, job_role):\n","    # Extract skills from resume\n","    resume_lower = resume_text.lower()\n","\n","    # Get role specific skills\n","    role_skill_list = role_skills.get(job_role, [])\n","\n","    # Find which skills candidate already has\n","    candidate_skills = [\n","        skill.title()\n","        for skill in role_skill_list\n","        if skill.lower() in resume_lower\n","    ]\n","\n","    # Pick top 3 skills for objective\n","    top_skills = candidate_skills[:3] if candidate_skills else ['various technical tools']\n","    skills_str = ', '.join(top_skills)\n","\n","    # Get template and fill in skills\n","    template = objective_templates.get(job_role,\n","        \"Motivated professional with expertise in {skills}, seeking to \"\n","        \"contribute skills and experience in a challenging role.\"\n","    )\n","\n","    objective = template.format(skills=skills_str)\n","    return objective\n","\n","# Step 7 - Resume Completeness Score\n","def calculate_completeness(found_sections, total_sections=7):\n","    score = (len(found_sections) / total_sections) * 100\n","    return round(score, 1)\n","\n","# Step 8 - MAIN Enhancement Function\n","def enhance_resume(resume_text, job_role):\n","\n","    print(\"\\n\")\n","    print(\"╔\" + \"═\" * 58 + \"╗\")\n","    print(\"║\" + \"✨ RESUME ENHANCEMENT REPORT\".center(58) + \"║\")\n","    print(\"╚\" + \"═\" * 58 + \"╝\")\n","\n","    # ── Section Analysis ──\n","    print(\"\\n┌\" + \"─\" * 58 + \"┐\")\n","    print(\"│\" + \"  📋 SECTION COMPLETENESS CHECK\".ljust(58) + \"│\")\n","    print(\"└\" + \"─\" * 58 + \"┘\")\n","\n","    found_sections, missing_sections = check_resume_sections(resume_text)\n","    completeness = calculate_completeness(found_sections)\n","\n","    print(f\"\\n  📊 Resume Completeness : {completeness}%\")\n","    print(f\"\\n  ✅ Sections Found ({len(found_sections)}):\")\n","    for section in found_sections:\n","        print(f\"     ✅ {section}\")\n","\n","    if missing_sections:\n","        print(f\"\\n  ❌ Sections Missing ({len(missing_sections)}):\")\n","        for section in missing_sections:\n","            print(f\"     ❌ {section} — Add this section!\")\n","    else:\n","        print(\"\\n  🎉 All sections present!\")\n","\n","    # ── Weak Words Analysis ──\n","    print(\"\\n┌\" + \"─\" * 58 + \"┐\")\n","    print(\"│\" + \"  ⚠️  WEAK WORDS DETECTOR\".ljust(58) + \"│\")\n","    print(\"└\" + \"─\" * 58 + \"┘\")\n","\n","    weak_words_found = detect_weak_words(resume_text)\n","\n","    if weak_words_found:\n","        print(f\"\\n  ⚠️  Found {len(weak_words_found)} weak word(s) in your resume!\")\n","        print(f\"  Replace them with these power words:\\n\")\n","        for weak, strong in weak_words_found.items():\n","            print(f\"  ❌